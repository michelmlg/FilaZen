# ========================
# PostgreSQL
# ========================
POSTGRES_USER=filazen
POSTGRES_PASSWORD=filazen_secret
POSTGRES_DB=filazen_db
POSTGRES_PORT=5432

# ========================
# Backend
# ========================
NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://filazen:filazen_secret@postgres:5432/filazen_db?schema=public"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ========================
# Frontend
# ========================
VITE_API_BASE_URL=http://localhost:3000
VITE_API_PREFIX=/api/v1
VITE_WS_URL=http://localhost:3000
